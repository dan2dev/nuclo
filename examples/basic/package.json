{
  "name": "001-counter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"deno run server \"",
    "dev:vite": "vite",
    "dev:server": "deno run --allow-net --allow-read --allow-env --allow-write src/server.ts",
    "build": "tsc && vite build",
    "prepreview": "tsc && vite build",
    "preview": "vite preview",
    "server": "deno run src/server.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "happy-dom": "^20.9.0",
    "hono": "^4.12.19"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "concurrently": "^9.2.1",
    "nuclo": "workspace:*",
    "tsx": "^4.22.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.13"
  }
}
