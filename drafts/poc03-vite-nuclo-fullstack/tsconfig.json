{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "@types/bun"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,

    /* Nuclo path aliases */
    "paths": {
      "nuclo": ["../../packages/nuclo-core/src/index.ts"],
      "nuclo/ssr": ["../../packages/nuclo-core/src/ssr/index.ts"],
      "nuclo/polyfill": ["../../packages/nuclo-core/src/polyfill/index.ts"]
    }
  },
  "include": ["src"]
}
