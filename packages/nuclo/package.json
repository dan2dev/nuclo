{
  "name": "nuclo",
  "private": false,
  "version": "0.1.38",
  "type": "module",
  "main": "./dist/nuclo.cjs",
  "module": "./dist/nuclo.js",
  "browser": "./dist/nuclo.umd.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/nuclo.js",
      "require": "./dist/nuclo.cjs"
    },
    "./types": {
      "types": "./types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "types"
  ],
  "scripts": {
    "build": "rimraf dist && rollup -c && tsc --emitDeclarationOnly",
    "dev": "rimraf dist && concurrently \"rollup -c -w\" \"tsc --emitDeclarationOnly --watch\"",
    "dev:all": "concurrently \"pnpm dev\" \"cd examples/basic && npm run dev\"",
    "build:watch": "rimraf dist && concurrently \"rollup -c -w\" \"tsc --emitDeclarationOnly --watch\"",
    "build:rollup": "rollup -c",
    "build:types": "tsc --emitDeclarationOnly",
    "clean": "rimraf dist && rimraf *.tsbuildinfo",
    "test": "vitest run --coverage",
    "test:watch": "vitest --watch"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/node": "^24.9.0",
    "@vitest/coverage-v8": "3.2.4",
    "jsdom": "^27.0.1",
    "rollup": "^4.52.5",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "concurrently": "^9.0.1",
    "rimraf": "^6.0.1"
  },
  "packageManager": "pnpm@10.18.3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dan2dev/nuclo.git"
  },
  "bugs": {
    "url": "https://github.com/dan2dev/nuclo/issues"
  },
  "homepage": "https://dan2dev.github.io/nuclo/"
}
