{
	"name": "nuclo",
	"private": false,
	"version": "0.2.5",
	"type": "module",
	"main": "./dist/nuclo.cjs",
	"module": "./dist/nuclo.mjs",
	"browser": "./dist/nuclo.umd.js",
	"types": "./types/index.d.ts",
	"exports": {
		".": {
			"types": "./types/index.d.ts",
			"import": "./dist/nuclo.mjs",
			"require": "./dist/nuclo.cjs"
		},
		"./ssr": {
			"types": "./dist/ssr/index.d.ts",
			"import": "./dist/ssr/nuclo.ssr.mjs",
			"require": "./dist/ssr/nuclo.ssr.cjs"
		},
		"./polyfill": {
			"types": "./dist/polyfill/index.d.ts",
			"import": "./dist/polyfill/nuclo.polyfill.mjs",
			"require": "./dist/polyfill/nuclo.polyfill.cjs"
		},
		"./types": {
			"types": "./types/index.d.ts"
		}
	},
	"files": [
		"dist",
		"types"
	],
	"scripts": {
		"build": "tsdown && tsc --emitDeclarationOnly",
		"dev": "tsdown --watch",
		"dev:all": "bun dev & cd examples/basic && bun run dev",
		"build:watch": "tsdown --watch",
		"build:types": "tsc --emitDeclarationOnly",
		"clean": "rm -rf dist *.tsbuildinfo",
		"typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
		"test": "npm run typecheck && vitest run --coverage",
		"test:watch": "vitest --watch --coverage",
		"bench": "bun bench/ssr.bench.ts && bun bench/hydrate.bench.ts",
		"bench:jfb": "bun bench/js-framework.bench.ts",
		"lint": "eslint . --ext .ts,.js,.json,.jsonc,.json5,.md,.css",
		"lint:fix": "eslint . --ext .ts,.js,.json,.jsonc,.json5,.md,.css --fix"
	},
	"devDependencies": {
		"@eslint/css": "^1.3.0",
		"@eslint/js": "^10.0.1",
		"@eslint/json": "^2.0.0",
		"@eslint/markdown": "^8.0.2",
		"@types/node": "^25.9.4",
		"@vitest/coverage-v8": "4.1.7",
		"eslint": "^10.5.0",
		"globals": "^17.6.0",
		"jiti": "^2.7.0",
		"jsdom": "^29.1.1",
		"tsdown": "^0.22.3",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.1",
		"vitest": "^4.1.9"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/dan2dev/nuclo.git"
	},
	"bugs": {
		"url": "https://github.com/dan2dev/nuclo/issues"
	},
	"homepage": "https://nuclo.dev/"
}
