                              "fill": "#A8B4C8",
                              "content": "// No breakpoints: pure style factory\nconst cn = createStyleQueries({});\n\n// With named breakpoints\nconst cn = createStyleQueries({\n  medium: '@media (min-width: 768px)',\n  large:  '@media (min-width: 1024px)',\n  dark:   '@media (prefers-color-scheme: dark)'\n});\n\n// Use the returned cn() anywhere in your app\nconst cardStyle = cn(\n  bg('white').padding('24px').borderRadius('12px'),\n  { medium: padding('32px') } // responsive override\n);",
                              "lineHeight": 1.75,
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 13,
