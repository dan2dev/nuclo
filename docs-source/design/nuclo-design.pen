                              "content": "let isLoggedIn = false;\nlet role = 'user'; // 'admin' | 'user' | 'guest'\n\n// Simple if/else\nwhen(() => isLoggedIn,\n  div('Welcome back!')\n).else(\n  div('Please log in')\n);\n\n// if / else-if / else\nwhen(() => role === 'admin',\n  div('Admin Panel')\n).when(() => role === 'user',\n  div('User Dashboard')\n).else(\n  div('Guest View')\n);",
                              "lineHeight": 1.75,
                              "fontFamily": "JetBrains Mono",
