                              "id": "7OTQe",
                              "fill": "#A8B4C8",
                              "content": "// Each helper returns a new StyleBuilder — chain as many as you need\nconst cardStyle = cn(\n  bg('white')\n    .padding('24px')\n    .borderRadius('16px')\n    .boxShadow('0 4px 12px rgba(0,0,0,0.08)')\n    .border('1px solid #e5e5df')\n);\n\n// Reuse a base style, branch to derive variants\nconst base = bg('#111').color('white').padding('10px 20px').borderRadius('6px');\nconst primary = cn(base.bg('#3b82f6'));\nconst danger  = cn(base.bg('#ef4444'));\n\ndiv(primary, 'Submit');\ndiv(danger,  'Delete');",
                              "lineHeight": 1.75,
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            }
