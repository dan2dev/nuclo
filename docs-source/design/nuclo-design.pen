                              "type": "text",
                              "id": "sq8pl",
                              "fill": "#A8B4C8",
                              "content": "let todos = [\n  { id: 1, text: 'Learn nuclo', done: false },\n  { id: 2, text: 'Build app', done: false }\n];\n\nlist(() => todos, (todo, index) =>\n  div(\n    span(() => `${index + 1}. ${todo.text}`),\n    button('Toggle', on('click', () => {\n      todo.done = !todo.done; // ✓ Mutate in-place\n      update();\n    }))\n  )\n);\n\n// Filter list: provider re-evaluates on update()\nlist(() => todos.filter(t => !t.done), todo =>\n  div(todo.text)\n);",
                              "lineHeight": 1.75,
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
