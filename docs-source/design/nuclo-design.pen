                            20
                          ],
                          "children": [
                            {
                              "type": "text",
                              "id": "FSBsX",
                              "fill": "#A8B4C8",
                              "content": "import 'nuclo';\n\nlet count = 0;\n\nconst app = div(\n  h1(() => `Count: ${count}`),\n  button('Increment', on('click', () => {\n    count++;\n    update();\n  })),\n  button('Decrement', on('click', () => {\n    count--;\n    update();\n  })),\n  button('Reset', on('click', () => {\n    count = 0;\n    update();\n  }))\n);\n\nrender(app, document.body);",
                              "lineHeight": 1.75,
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
